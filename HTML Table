<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTML TABLE</title>
</head>
<body>
    <!-- cellspacing : space around the border of the cell/space between the cells
    cellpadding : space around the content of the cell/ space between the content and border of the cell -->
    <h2>EMPLOYE TABLE</h2>
    <table border="1" cellspacing="10px" cellpadding="20px" height="500px" width="900px" style="text-align: center;">
        <thead>
            <tr>
                <th>SL.NO.</th>
                <th>EMPLOYEE NAME</th>
                <th>SALARY</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>1</td>
                <td>TANVI</td>
                <td>30000</td>
            </tr>
            <tr>
                <td>2</td>
                <td>BHUVANA</td>
                <td rowspan="2">50000</td>
            </tr>
            <tr>
                <td>3</td>
                <td>YASHU</td>
                <!-- <td>50000</td> -->
            </tr>
            <tr>
                <td>4</td>
                <td>PRIYA</td>
                <td>40000</td>
            </tr>
            <tr>
                <td>5</td>
                <td>SNEHAL</td>
                <td>45000</td>
            </tr>
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3">TOTAL NO.OF EMPLOYEE : 5</td>
                <!-- <td></td>
                <td></td> -->
            </tr>
        </tfoot>
    </table>
</body>
</html> 
